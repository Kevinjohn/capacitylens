{
  "name": "capacitylens",
  "private": true,
  "version": "0.13.0",
  "license": "AGPL-3.0-only",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide",
    "dev": "node scripts/dev-fullstack.mjs",
    "dev:web": "npm run paraglide:compile && vite",
    "dev:demo": "npm run paraglide:compile && VITE_CAPACITYLENS_DEMO=1 vite",
    "build": "npm run paraglide:compile && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "npm run paraglide:compile && vitest run",
    "test:watch": "npm run paraglide:compile && vitest",
    "coverage": "npm run paraglide:compile && vitest run --coverage",
    "dev:api": "npm run paraglide:compile && vite --port 5273",
    "dev:auth": "npm run paraglide:compile && vite --port 5373",
    "e2e": "playwright test",
    "e2e:webkit": "CAPACITYLENS_WEBKIT_ONLY=1 playwright test --project=webkit",
    "e2e:firefox": "CAPACITYLENS_FIREFOX_ONLY=1 playwright test --project=firefox",
    "e2e:browsers": "node scripts/e2e-browsers.mjs",
    "e2e:all": "node scripts/e2e-all.mjs",
    "gate": "npm run paraglide:compile && tsc -b && eslint . && vitest run && vite build",
    "mutation": "npm run paraglide:compile && stryker run",
    "test:server": "npm test -w capacitylens-server",
    "gate:server": "npm run type-check -w capacitylens-server && npm test -w capacitylens-server"
  },
  "dependencies": {
    "@capacitylens/shared": "*",
    "better-auth": "^1.6.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.3.0",
    "lucide-react": "^1.21.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.16.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@inlang/paraglide-js": "^2.20.2",
    "@playwright/test": "^1.60.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.7"
  },
  "workspaces": [
    "shared",
    "server"
  ]
}
