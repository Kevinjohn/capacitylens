# CapacityLens — example environment. Copy to `.env` (compose auto-loads it from
# this directory) and fill in what you need. EVERY runtime variable the app and
# server actually read is listed here; all are OPTIONAL unless marked REQUIRED.
#
# Two kinds of variable:
#   - Server runtime (CAPACITYLENS_* / BETTER_AUTH_*): read by the Fastify daemon
#     at start. Change .env + `docker compose up` to apply.
#   - Client build-time (VITE_CAPACITYLENS_*): INLINED into the SPA at build, so a
#     change needs a rebuild (`docker compose build web` / `--build`).
#
# Boolean flags are ON only when set to exactly `1`; anything else (incl. unset)
# is OFF, except optimistic concurrency which is secure-by-default and uses `0`
# as its explicit opt-out. NEVER commit a real .env — keep secrets out of version control.

# ===========================================================================
# Server runtime
# ===========================================================================

# Listen port for the API daemon. Default 8787. nginx proxies /api here.
PORT=8787

# Bind address. Default 127.0.0.1 (loopback only). In Docker this does NOTHING —
# the api image bakes CAPACITYLENS_HOST=0.0.0.0 and compose never forwards this var.
# Uncomment ONLY if you're running this file bare-metal (no Docker) and deliberately
# want to expose the API on the LAN; the secure default is loopback-only.
# CAPACITYLENS_HOST=0.0.0.0

# SQLite database file. Default ./capacitylens.db. In compose this points into
# the named `capacitylens-db` volume so data survives rebuilds. `:memory:` works
# for throwaway runs.
CAPACITYLENS_DB=/data/capacitylens.db

# Directory for periodic online DB snapshots. In compose this points into the
# `capacitylens-backups` volume and backups are ON by default; set it EXPLICITLY
# EMPTY (CAPACITYLENS_BACKUP_DIR=) to disable them (no timer, no writes) —
# compose only falls back to /backups when the var is fully unset.
CAPACITYLENS_BACKUP_DIR=/backups

# Snapshot cadence in minutes. Default 60. Only read when backups are ON.
# CAPACITYLENS_BACKUP_INTERVAL_MIN=60

# Rolling retention count (oldest pruned). Default 48. Only read when backups ON.
# CAPACITYLENS_BACKUP_KEEP=48

# CORS allow-list: comma-separated origins, or `*` for any. UNSET = fail-closed
# localhost dev defaults (NOT open). With the same-origin nginx /api proxy you
# can leave this unset — the browser never makes a cross-origin API call.
# CAPACITYLENS_CORS_ORIGIN=https://your.host

# `1` exposes the destructive POST /api/test/reset route (dev/E2E ONLY). The
# server REFUSES to boot if this is 1 while NODE_ENV=production. Leave unset.
# CAPACITYLENS_ALLOW_RESET=1

# Stale overwrites are rejected with HTTP 409 by default. Set `0` only for a
# deliberate trusted single-writer deployment.
# CAPACITYLENS_OPTIMISTIC_CONCURRENCY=0

# `1` when the public origin is real HTTPS — enables the HSTS header. Default off:
# HSTS is invalid/harmful over plain HTTP, and this server usually runs HTTP behind
# a TLS-terminating reverse proxy (nginx/Forge). The other baseline security headers
# (nosniff, CSP, Referrer-Policy, X-Frame-Options) are always on regardless.
# CAPACITYLENS_HTTPS=1

# `1` for structured per-request JSON logs (pino). Default off = startup line +
# console.error on 500s. Recommended `1` for a deployment.
CAPACITYLENS_LOG=1

# `1` makes /api/health also do a trivial DB read (-> { ok, db } or 503). Default
# off = unconditional { ok: true }. Recommended `1` for a real healthcheck.
CAPACITYLENS_HEALTH_DEEP=1

# Requests/minute per IP across /api/* (positive integer; /api/health exempt).
# Unset / 0 / non-numeric = no rate limiting (fail-closed off).
CAPACITYLENS_RATE_LIMIT=300

# Trust the single X-Forwarded-For value supplied by a front proxy for per-client rate limits.
# Enable ONLY when the API is unreachable directly and the proxy overwrites (does not append)
# that header. Compose pins this to 1 because only packaged nginx can reach its API service.
# CAPACITYLENS_RATE_LIMIT_TRUST_FORWARDED=1

# Constrained org-creation (POST /api/orgs). Shared secret sent as the request
# header `x-capacitylens-bootstrap-token` to authorise creating an account when the
# caller is NOT yet an Owner/Admin of any account (e.g. provisioning the 2nd org on
# an instance that already has one). OFF BY DEFAULT (unset/empty = the token path
# never allows): org-creation is then first-run-only (zero accounts) or an existing
# Owner/Admin. Use a long random value, e.g. `openssl rand -base64 32`. NOTE: the
# token now PRESUMES a multi-account instance — it only matters once
# CAPACITYLENS_MULTI_ACCOUNT=1 below, since the single-company cap denies every
# create (token or not) while the instance is capped to one company.
# CAPACITYLENS_BOOTSTRAP_TOKEN=replace-with-a-long-random-secret

# `1` allows more than one company (`accounts` row) on this instance. OFF BY DEFAULT:
# CapacityLens is single-company-per-instance — once the first company is created,
# every create-a-company vector (POST /api/accounts, POST /api/orgs, a create-shaped
# PUT/batch-PUT) 403s with "This instance allows a single company. Set
# CAPACITYLENS_MULTI_ACCOUNT=1 to allow more." in EVERY auth mode, including off.
# Enforcement is create-time only — an existing DB with several companies keeps
# working either way; updates/deletes are never affected.
# CAPACITYLENS_MULTI_ACCOUNT=1

# `1` seeds the two-company demo dataset (Studio North + Loft Digital) on a
# never-initialised DB at boot. OFF BY DEFAULT: a fresh real server now starts
# EMPTY — the first-run experience is creating your one company at the account
# picker. Only makes sense paired with CAPACITYLENS_MULTI_ACCOUNT=1 above (the seed
# ships TWO companies, which the single-company cap would otherwise immediately
# contradict). `npm run dev` sets both for you (scripts/dev-fullstack.mjs), so the
# everyday dev experience is unchanged — use this var directly only for a
# throwaway/demo server instance.
# CAPACITYLENS_SEED_DEMO=1

# Append-only JSONL audit log of every AppData mutation (who/when/what changed —
# field NAMES only, e.g. `["note","startDate"]`, NEVER values, so no PII reaches
# the log). ON BY DEFAULT (server mode only); set to `off` to disable.
# CAPACITYLENS_AUDIT=off

# Audit log path. Default: `capacitylens-audit.jsonl` next to CAPACITYLENS_DB (a
# `:memory:` DB falls back to a CWD-relative file). Only read when audit is ON.
# CAPACITYLENS_AUDIT_FILE=/data/capacitylens-audit.jsonl

# Audit log rotation cap in MB (positive integer). Default 64: once the file
# reaches this size it's rotated to `<file>.1` (the previous `.1` is replaced),
# bounding disk use at roughly 2x the cap. Only read when audit is ON.
# CAPACITYLENS_AUDIT_MAX_MB=64

# ===========================================================================
# Auth (Better Auth) — OFF by default
# ===========================================================================

# off | password | sso. UNSET or `off` = no Better Auth at all (no tables, no
# BETTER_AUTH_* read, only the thin /api/auth/me). Any other value refuses boot.
# CAPACITYLENS_AUTH=off

# REQUIRED when CAPACITYLENS_AUTH is password or sso. Session signing secret,
# 32+ random chars. Generate, e.g.: `openssl rand -base64 32`.
# BETTER_AUTH_SECRET=replace-with-32+char-random-string

# REQUIRED when CAPACITYLENS_AUTH is password or sso. The public origin the
# browser uses to reach the app (e.g. https://your.host).
# BETTER_AUTH_URL=https://your.host

# `1` re-opens OPEN email self-registration (POST /api/auth/sign-up/email).
# CLOSED BY DEFAULT (unset): self-service signup is invite-only by design, so open
# registration is impossible out of the box. This is an INTERIM trusted-instance/dev
# escape until the invite flow lands; leave UNSET in production.
# CAPACITYLENS_ALLOW_OPEN_SIGNUP=1

# Creates a first-run admin identity with a fresh random password printed once to the
# server log. The password is never the historical admin/admin default. Remove after use.
# CAPACITYLENS_CREATE_ADMIN_ADMIN=1

# REQUIRED for a fresh password-mode instance unless open signup or the explicit
# bootstrap-admin switch is enabled. The first-owner form sends this secret in
# `x-capacitylens-setup-token`; after the first identity exists, signup closes even
# when the token is presented. Generate a long random value, e.g.
# `openssl rand -base64 32`.
# CAPACITYLENS_SETUP_TOKEN=replace-with-a-long-random-secret

# `1` ONLY to deliberately run the open/demo (auth-off) posture under
# NODE_ENV=production — otherwise auth-off in production refuses to boot (the demo
# dataset would be world-readable/writable). OFF BY DEFAULT (unset); leave UNSET and
# set CAPACITYLENS_AUTH=password|sso for a real deployment.
# CAPACITYLENS_ALLOW_OPEN_IN_PRODUCTION=1

# ===========================================================================
# Social SSO providers (Google / Microsoft / GitHub) — all OPTIONAL
# ===========================================================================
# Each provider is offered ONLY when BOTH its CLIENT_ID and CLIENT_SECRET are set
# (a half-configured provider is silently skipped). Active in password/sso modes;
# additive to the generic OIDC provider below. Social sign-in is the primary path.

# Google OAuth client (from Google Cloud Console).
# CAPACITYLENS_GOOGLE_CLIENT_ID=your-google-client-id
# CAPACITYLENS_GOOGLE_CLIENT_SECRET=your-google-client-secret

# Microsoft Entra ID app registration. TENANT_ID is optional (default `common`,
# i.e. multi-tenant); pin it to a single tenant id to lock sign-in to one org.
# CAPACITYLENS_MICROSOFT_CLIENT_ID=your-microsoft-client-id
# CAPACITYLENS_MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
# CAPACITYLENS_MICROSOFT_TENANT_ID=common

# GitHub OAuth App (from GitHub Developer settings).
# CAPACITYLENS_GITHUB_CLIENT_ID=your-github-client-id
# CAPACITYLENS_GITHUB_CLIENT_SECRET=your-github-client-secret

# ===========================================================================
# Generic OIDC SSO (only when CAPACITYLENS_AUTH=sso)
# ===========================================================================

# Optional provider id used in the auth routes. Default `sso`.
# CAPACITYLENS_SSO_PROVIDER_ID=sso

# REQUIRED for sso: the OIDC client credentials from your identity provider.
# CAPACITYLENS_SSO_CLIENT_ID=your-oidc-client-id
# CAPACITYLENS_SSO_CLIENT_SECRET=your-oidc-client-secret

# Provide EITHER the discovery URL, OR both the authorization + token URLs.
# CAPACITYLENS_SSO_DISCOVERY_URL=https://idp.example.com/.well-known/openid-configuration
# CAPACITYLENS_SSO_AUTHORIZATION_URL=https://idp.example.com/authorize
# CAPACITYLENS_SSO_TOKEN_URL=https://idp.example.com/token

# Space-separated OIDC scopes. Default `openid profile email`.
# CAPACITYLENS_SSO_SCOPES=openid profile email

# ===========================================================================
# Client build-time (Vite) — inlined into the SPA at build, change needs rebuild
# ===========================================================================

# Backend base ORIGIN the SPA talks to. The client appends `/api` itself, so set
# the ORIGIN (NOT `/api` — that would request /api/api/...). EMPTY (the default) =
# SERVER MODE against the SAME ORIGIN: the SPA calls a relative `/api`, which the
# nginx proxy serves same-origin — works on any host with no per-host rebuild. Set
# this only to point the SPA at a DIFFERENT origin than the one serving it.
# NOTE: empty no longer means localStorage — server is the default now (see DEMO below).
VITE_CAPACITYLENS_API=

# Build the in-browser localStorage DEMO (zero setup, no backend, no login) instead
# of the server build. `1` is the ONLY way to get localStorage now, and it wins even
# if VITE_CAPACITYLENS_API is also set. Leave unset/empty for the normal server build.
# REQUIRED for any build deployed WITHOUT a same-origin /api backend (a plain static
# host, `vite preview`, a demo link): empty env is server mode and will NOT silently
# fall back to localStorage — a backend-less server build boots into a "can't reach the
# server" screen. Set this to `1` for those builds.
# VITE_CAPACITYLENS_DEMO=1

# Optional build identifier shown in the build stamp (Settings). Typically the
# git SHA. Empty = no SHA shown.
# VITE_CAPACITYLENS_BUILD_SHA=

# Optional mailto address for the in-app feedback link. Empty = link hidden.
# VITE_CAPACITYLENS_FEEDBACK_MAILTO=feedback@example.com

# ===========================================================================
# Process
# ===========================================================================

# Node environment. The api image sets `production`. Note: NODE_ENV=production
# together with CAPACITYLENS_ALLOW_RESET=1 makes the server refuse to boot.
NODE_ENV=production
