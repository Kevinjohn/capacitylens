# CapacityLens — example environment. Copy to `.env` (compose auto-loads it from
# this directory) and fill in what you need. EVERY runtime variable the app and
# server actually read is listed here; all are OPTIONAL unless marked REQUIRED.
#
# Two kinds of variable:
#   - Server runtime (CAPACITYLENS_* / SMALLSASS_ACCOUNT_*): read by the Fastify daemon
#     at start. Change .env + `docker compose up` to apply.
#   - Client build-time (VITE_CAPACITYLENS_*): INLINED into the SPA at build, so a
#     change needs a rebuild (`docker compose build web` / `--build`).
#
# Boolean flags are ON only when set to exactly `1`; anything else (incl. unset)
# is OFF, except optimistic concurrency which is secure-by-default and uses `0`
# as its explicit opt-out. NEVER commit a real .env — keep secrets out of version control.

# Compose publishes the web edge on loopback by default so only a local TLS reverse proxy can
# reach it. Override this only when a private platform load balancer must connect to the host.
# That edge must overwrite X-Forwarded-Proto with the browser-visible scheme.
# WEB_BIND_IP=127.0.0.1
# WEB_PORT=8080

# ===========================================================================
# Server runtime
# ===========================================================================

# Listen port for the API daemon. Default 8787. nginx proxies /api here.
PORT=8787

# Bind address. Default 127.0.0.1 (loopback only). In Docker this does NOTHING —
# the api image bakes CAPACITYLENS_HOST=0.0.0.0 and compose never forwards this var.
# Uncomment ONLY if you're running this file bare-metal (no Docker) and deliberately
# want to expose the API on the LAN; the secure default is loopback-only.
# CAPACITYLENS_HOST=0.0.0.0

# SQLite database file. Default ./capacitylens.db. In compose this points into
# the named `capacitylens-db` volume so data survives rebuilds. `:memory:` works
# for throwaway runs.
CAPACITYLENS_DB=/data/capacitylens.db

# Directory for periodic online DB snapshots. In compose this points into the
# `capacitylens-backups` volume and backups are ON by default; set it EXPLICITLY
# EMPTY (CAPACITYLENS_BACKUP_DIR=) to disable them (no timer, no writes) —
# compose only falls back to /backups when the var is fully unset.
CAPACITYLENS_BACKUP_DIR=/backups

# Snapshot cadence in minutes. Default 60. Only read when backups are ON.
# CAPACITYLENS_BACKUP_INTERVAL_MIN=60

# Rolling retention count (oldest pruned). Default 48. Only read when backups ON.
# CAPACITYLENS_BACKUP_KEEP=48

# CORS allow-list: comma-separated exact origins. `*` is rejected because browser
# authentication uses cookies. UNSET = fail-closed localhost dev defaults (NOT open).
# With the same-origin nginx /api proxy you
# can leave this unset — the browser never makes a cross-origin API call.
# CAPACITYLENS_CORS_ORIGIN=https://your.host

# `1` exposes the destructive POST /api/test/reset route (dev/E2E ONLY). The
# server REFUSES to boot if this is 1 while NODE_ENV=production. Leave unset.
# CAPACITYLENS_ALLOW_RESET=1

# Stale overwrites are rejected with HTTP 409 by default. Set `0` only for a
# deliberate trusted single-writer deployment.
# CAPACITYLENS_OPTIMISTIC_CONCURRENCY=0

# `1` when the public origin is real HTTPS — enables a two-year HSTS header with
# includeSubDomains. Default off:
# HSTS is invalid/harmful over plain HTTP, and this server usually runs HTTP behind
# a TLS-terminating reverse proxy (nginx/Forge). The other baseline security headers
# (nosniff, CSP, Referrer-Policy, X-Frame-Options) are always on regardless.
# CAPACITYLENS_HTTPS=1

# Optional internal reverse-proxy/API HTTPS identity. Omit both for HTTP on a trusted same-host
# loopback hop; production logs a warning but continues. If either is configured, both are required
# and unreadable/partial identities still refuse startup. Docker Compose supplies a private
# per-install CA automatically, so do not override these paths there.
# CAPACITYLENS_INTERNAL_TLS_CERT=/run/capacitylens-internal-tls/api.crt
# CAPACITYLENS_INTERNAL_TLS_KEY=/run/capacitylens-internal-tls/api.key
# Compose/Docker health-check helper only: CA used to verify the packaged API certificate. The
# packaged image sets this path; operators do not normally override it.
# CAPACITYLENS_INTERNAL_TLS_CA=/run/capacitylens-internal-tls/ca.crt

# `1` for structured per-request JSON logs (pino). Default off = startup line +
# console.error on 500s. Recommended `1` for a deployment.
CAPACITYLENS_LOG=1

# `1` makes /api/health execute a constant `SELECT 1` readiness query and report audit
# degradation (-> { ok, db, audit } or 503). Default off = liveness-only { ok: true }.
# The check never reads tenant rows or performs a full foreign-key scan.
CAPACITYLENS_HEALTH_DEEP=1

# Requests/minute per IP across rate-limited /api/* routes (positive integer). `/api/health` is
# deliberately exempt so ordinary API traffic cannot starve the public uptime probe.
# Unset / 0 / non-numeric disables rate limiting in development; production refuses boot.
CAPACITYLENS_RATE_LIMIT=300

# Trust the single X-Forwarded-For value supplied by a front proxy for per-client rate limits.
# Enable ONLY when the API is unreachable directly and the proxy overwrites (does not append)
# that header. Compose pins this to 1 because only packaged nginx can reach its API service.
# CAPACITYLENS_RATE_LIMIT_TRUST_FORWARDED=1

# Constrained org-creation (POST /api/orgs). Shared secret sent as the request
# header `x-capacitylens-bootstrap-token` to authorise creating an account when the
# caller is NOT yet an Owner/Admin of any account (e.g. provisioning the 2nd org on
# an instance that already has one). OFF BY DEFAULT (unset/empty = the token path
# never allows): org-creation is then first-run-only (zero accounts) or an existing
# Owner/Admin. Use a long random value, e.g. `openssl rand -base64 32`. NOTE: the
# token now PRESUMES a multi-account instance — it only matters once
# CAPACITYLENS_MULTI_ACCOUNT=1 below, since the single-company cap denies every
# create (token or not) while the instance is capped to one company.
# CAPACITYLENS_BOOTSTRAP_TOKEN=replace-with-a-long-random-secret

# `1` allows more than one company (`accounts` row) on this instance. OFF BY DEFAULT:
# CapacityLens is single-company-per-instance — once the first company is created,
# every create-a-company vector (POST /api/accounts, POST /api/orgs, a create-shaped
# PUT/batch-PUT) 403s with "This instance allows a single company. Set
# CAPACITYLENS_MULTI_ACCOUNT=1 to allow more." in EVERY auth mode, including off.
# Enforcement is create-time only — an existing DB with several companies keeps
# working either way; updates/deletes are never affected.
# CAPACITYLENS_MULTI_ACCOUNT=1

# `1` seeds the two-company demo dataset (Studio North + Loft Digital) on a
# never-initialised DB at boot. OFF BY DEFAULT: a fresh real server now starts
# EMPTY — the first-run experience is creating your one company at the account
# picker. Only makes sense paired with CAPACITYLENS_MULTI_ACCOUNT=1 above (the seed
# ships TWO companies, which the single-company cap would otherwise immediately
# contradict). `npm run dev` sets both for you (scripts/dev-fullstack.mjs), so the
# everyday dev experience is unchanged — use this var directly only for a
# throwaway/demo server instance.
# CAPACITYLENS_SEED_DEMO=1

# Append-only JSONL audit log of every AppData mutation (who/when/what changed —
# field NAMES only, e.g. `["note","startDate"]`, NEVER values, so no PII reaches
# the log). ON BY DEFAULT (server mode only); set to `off` to disable.
# CAPACITYLENS_AUDIT=off

# Audit log path. Default: `capacitylens-audit.jsonl` next to CAPACITYLENS_DB (a
# `:memory:` DB falls back to a CWD-relative file). Only read when audit is ON.
# CAPACITYLENS_AUDIT_FILE=/data/capacitylens-audit.jsonl

# Audit log rotation cap in MB (positive integer). Default 64: once the file
# reaches this size it's rotated to `<file>.1` (the previous `.1` is replaced),
# bounding disk use at roughly 2x the cap. Only read when audit is ON.
# CAPACITYLENS_AUDIT_MAX_MB=64

# `1` also writes each typed audit envelope as one JSON line to process stdout for a container/log
# collector. Compose defaults this ON. File audit remains independently enabled unless AUDIT=off.
# CAPACITYLENS_AUDIT_STDOUT=1

# ===========================================================================
# Account layer — OFF by default
# ===========================================================================

# Optional named policy profile. When present, the profile is enforced at boot:
# self-hosted-password | self-hosted-mixed | self-hosted-sso-only | hosted-oidc-only.
# Hosted is permanently strict-OIDC-only; password settings make it refuse startup.
# SMALLSASS_ACCOUNT_DEPLOYMENT_PROFILE=self-hosted-password

# off | password | sso. UNSET or `off` creates no auth-provider instance. The hosted profile
# requires `sso`; open-source operators remain free to select any supported self-hosted profile.
# SMALLSASS_ACCOUNT_MODE=off

# `1` requires every password-mode identity to enroll TOTP MFA before tenant data is served.
# SMALLSASS_ACCOUNT_REQUIRE_MFA=1

# Operator attestation that the upstream IdP requires MFA for every admitted identity. Set only
# after testing the IdP policy, recovery and session behavior; production otherwise warns.
# SMALLSASS_ACCOUNT_SSO_MFA_ENFORCED=1

# Breached-password range screening defaults ON outside tests. Set `off` only for an isolated
# deployment that accepts the production warning and reduced protection.
# SMALLSASS_ACCOUNT_PASSWORD_BREACH_CHECK=on

# Optional production deployment attestations. These flags do not implement encryption or a
# collector: set them to `1` only after the host/platform encrypts the DB/audit/backup volumes and
# audit/security stdout is shipped to a separate monitored destination. Production warns when they
# are absent but remains usable for simple self-hosting.
# CAPACITYLENS_STORAGE_ENCRYPTED=1
# CAPACITYLENS_SECURITY_LOG_FORWARDING=1

# REQUIRED when account mode is password or sso. Local session signing secret,
# 32+ random chars. Generate, e.g.: `openssl rand -base64 32`.
# SMALLSASS_ACCOUNT_SECRET=replace-with-32+char-random-string

# REQUIRED when account mode is password or sso. The public origin the
# browser uses to reach the app (e.g. https://your.host).
# SMALLSASS_ACCOUNT_PUBLIC_URL=https://your.host

# `1` re-opens OPEN email self-registration (POST /api/auth/sign-up/email).
# CLOSED BY DEFAULT (unset): self-service signup is invite-only by design, so open
# registration is impossible out of the box. This is a trusted-instance/development
# escape; leave it UNSET in production.
# SMALLSASS_ACCOUNT_ALLOW_OPEN_SIGNUP=1

# DEVELOPMENT ONLY: creates a first-run admin identity with a fresh random password printed once to
# the server log. Production refuses this path because the initial password cannot be forced to
# expire after first use; use the setup-token owner flow there.
# CAPACITYLENS_CREATE_ADMIN_ADMIN=1

# DEVELOPMENT ONLY override for the bootstrap owner's otherwise-generated password. Production
# refuses it. Never commit the value.
# CAPACITYLENS_BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-secret-manager-value

# REQUIRED for a fresh password-mode instance unless open signup or the explicit
# bootstrap-admin switch is enabled. The first-owner form sends this secret in
# `x-capacitylens-setup-token`; after the first identity exists, signup closes even
# when the token is presented. Generate a long random value, e.g.
# `openssl rand -base64 32`.
# SMALLSASS_ACCOUNT_SETUP_TOKEN=replace-with-a-long-random-secret

# `1` ONLY to deliberately run the open/demo (auth-off) posture under
# NODE_ENV=production — otherwise auth-off in production refuses to boot (the demo
# dataset would be world-readable/writable). OFF BY DEFAULT (unset); leave UNSET and
# set SMALLSASS_ACCOUNT_MODE=password|sso for a real deployment.
# CAPACITYLENS_ALLOW_OPEN_IN_PRODUCTION=1

# ===========================================================================
# Named social providers (Google / Microsoft / GitHub) — OPTIONAL, EXPERIMENTAL
# ===========================================================================
# Each provider is offered only when both its CLIENT_ID and CLIENT_SECRET are set.
# A half-configured provider refuses startup. Active in password/sso modes and
# clearly marked experimental in the UI.

# Google OAuth client (from Google Cloud Console).
# SMALLSASS_ACCOUNT_GOOGLE_CLIENT_ID=your-google-client-id
# SMALLSASS_ACCOUNT_GOOGLE_CLIENT_SECRET=your-google-client-secret

# Microsoft Entra ID app registration. TENANT_ID is optional (default `common`,
# i.e. multi-tenant); pin it to a single tenant id to lock sign-in to one org.
# SMALLSASS_ACCOUNT_MICROSOFT_CLIENT_ID=your-microsoft-client-id
# SMALLSASS_ACCOUNT_MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
# SMALLSASS_ACCOUNT_MICROSOFT_TENANT_ID=common

# GitHub OAuth App (from GitHub Developer settings).
# SMALLSASS_ACCOUNT_GITHUB_CLIENT_ID=your-github-client-id
# SMALLSASS_ACCOUNT_GITHUB_CLIENT_SECRET=your-github-client-secret

# ===========================================================================
# Strict OIDC (FIRST-CLASS; additive in mixed mode, required in SSO-only modes)
# ===========================================================================

# Optional provider id used in the auth routes. Default `sso`.
# SMALLSASS_ACCOUNT_OIDC_PROVIDER_ID=sso

# Optional button label. Default `Single sign-on`.
# SMALLSASS_ACCOUNT_OIDC_LABEL=Company SSO

# Comma-separated verified emails allowed to create the FIRST external identity.
# Every later new external identity must match an unused, unexpired pre-authorised invite.
# SMALLSASS_ACCOUNT_OIDC_BOOTSTRAP_EMAILS=owner@example.com

# REQUIRED for sso: the OIDC client credentials from your identity provider.
# SMALLSASS_ACCOUNT_OIDC_CLIENT_ID=your-oidc-client-id
# SMALLSASS_ACCOUNT_OIDC_CLIENT_SECRET=your-oidc-client-secret

# Both the exact issuer and discovery URL are REQUIRED. Authorization, token, JWKS and user-info
# endpoints come only from discovery. Explicit endpoint overrides and arbitrary OAuth are refused.
# SMALLSASS_ACCOUNT_OIDC_ISSUER=https://idp.example.com
# SMALLSASS_ACCOUNT_OIDC_DISCOVERY_URL=https://idp.example.com/.well-known/openid-configuration

# Space-separated OIDC scopes. Default `openid profile email`.
# SMALLSASS_ACCOUNT_OIDC_SCOPES=openid profile email

# Compatibility: the former CAPACITYLENS_AUTH / BETTER_AUTH_* / CAPACITYLENS_SSO_* and named-social
# spellings remain aliases until BOTH two stable minor releases and 90 days have elapsed from the
# first stable release containing SMALLSASS_ACCOUNT_*. The current 0.25 alpha does not start that
# clock; record the eventual 0.25.0 release date, and remove no earlier than 0.27.0 and 90 days after
# that date. They warn once at startup. Canonical+legacy conflicts refuse boot. New deployments
# should use only the names above.
# Exact compatibility aliases retained only for that bounded window:
# CAPACITYLENS_AUTH, BETTER_AUTH_SECRET, BETTER_AUTH_URL, CAPACITYLENS_SETUP_TOKEN,
# CAPACITYLENS_ALLOW_OPEN_SIGNUP, CAPACITYLENS_REQUIRE_MFA, CAPACITYLENS_PASSWORD_BREACH_CHECK,
# CAPACITYLENS_SSO_MFA_ENFORCED, CAPACITYLENS_SSO_CLIENT_ID, CAPACITYLENS_SSO_CLIENT_SECRET,
# CAPACITYLENS_SSO_DISCOVERY_URL, CAPACITYLENS_SSO_ISSUER, CAPACITYLENS_SSO_AUTHORIZATION_URL,
# CAPACITYLENS_SSO_TOKEN_URL, CAPACITYLENS_SSO_SCOPES, CAPACITYLENS_SSO_PROVIDER_ID,
# CAPACITYLENS_SSO_LABEL, CAPACITYLENS_SSO_BOOTSTRAP_EMAILS, CAPACITYLENS_GOOGLE_CLIENT_ID,
# CAPACITYLENS_GOOGLE_CLIENT_SECRET, CAPACITYLENS_MICROSOFT_CLIENT_ID,
# CAPACITYLENS_MICROSOFT_CLIENT_SECRET, CAPACITYLENS_MICROSOFT_TENANT_ID,
# CAPACITYLENS_GITHUB_CLIENT_ID and CAPACITYLENS_GITHUB_CLIENT_SECRET.

# ===========================================================================
# Client build-time (Vite) — inlined into the SPA at build, change needs rebuild
# ===========================================================================

# Backend base ORIGIN the SPA talks to. The client appends `/api` itself, so set
# the ORIGIN (NOT `/api` — that would request /api/api/...). EMPTY (the default) =
# SERVER MODE against the SAME ORIGIN: the SPA calls a relative `/api`, which the
# nginx proxy serves same-origin — works on any host with no per-host rebuild. Set
# this only to point the SPA at a DIFFERENT origin than the one serving it.
# NOTE: empty no longer means localStorage — server is the default now (see DEMO below).
VITE_CAPACITYLENS_API=

# Build the in-memory demo (zero setup, no backend, no login) instead of the server
# build. Data resets on refresh. `1` is the only demo selector, and it wins even
# if VITE_CAPACITYLENS_API is also set. Leave unset/empty for the normal server build.
# REQUIRED for any build deployed WITHOUT a same-origin /api backend (a plain static
# host, `vite preview`, a demo link): empty env is server mode and will NOT silently
# fall back to browser persistence — a backend-less server build boots into a "can't reach the
# server" screen. Set this to `1` for those builds.
# VITE_CAPACITYLENS_DEMO=1

# Optional build identifier shown in the build stamp (Settings). Typically the
# git SHA. Empty = no SHA shown.
# VITE_CAPACITYLENS_BUILD_SHA=

# Optional mailto address for the in-app feedback link. Empty = link hidden.
# VITE_CAPACITYLENS_FEEDBACK_MAILTO=feedback@example.com

# ===========================================================================
# Process
# ===========================================================================

# Node environment. The api image sets `production`. Note: NODE_ENV=production
# together with CAPACITYLENS_ALLOW_RESET=1 makes the server refuse to boot.
NODE_ENV=production

# Developer helper only: API port used by scripts/dev-fullstack.mjs. Default 8787. Production reads
# PORT instead.
# CAPACITYLENS_DEV_API_PORT=8787

# Developer/test tooling is not server configuration and must not be placed in a production `.env`.
# `API_PORT` is the `scripts/serve-dist.mjs` proxy target (default 8787). Playwright orchestration
# owns CAPACITYLENS_E2E_PHASE, CAPACITYLENS_WEBKIT, CAPACITYLENS_WEBKIT_ONLY,
# CAPACITYLENS_FIREFOX, CAPACITYLENS_FIREFOX_ONLY, CAPACITYLENS_VITE_ONLY,
# CAPACITYLENS_OIDC_E2E and CAPACITYLENS_REHEARSAL_URL. The package scripts
# set the first seven; operators set only CAPACITYLENS_REHEARSAL_URL for a documented upgrade
# rehearsal. Standard tool variables such as CI, DEV and INIT_CWD retain their upstream meanings.
