{
  "name": "floaty-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "SQLite-backed entity-level REST API for Floaty. Imports the shared domain-core from ../src so server validation IS client validation.",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "start:e2e": "FLOATY_ALLOW_RESET=1 FLOATY_DB=.e2e.db tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/rate-limit": "^11.0.0",
    "@floaty/shared": "*",
    "better-auth": "^1.6.18",
    "fastify": "^5.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "~6.0.2",
    "vitest": "^4.1.7"
  }
}
